# Django Core
DJANGO_SECRET_KEY=django-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# Database
# For Render PostgreSQL, set DATABASE_URL=postgres://user:password@host:port/dbname
DATABASE_URL=sqlite:///db.sqlite3

# CORS configuration
# Allow all origins by default. To restrict, set CORS_RESTRICT=True and specify CORS_ORIGINS.
CORS_RESTRICT=False
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Email configuration (Brevo SMTP)
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
EMAIL_HOST_USER=your-brevo-login@example.com
EMAIL_HOST_PASSWORD=your-brevo-smtp-key
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=20

# OTP configuration
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_FAILED_ATTEMPTS=5

# Paystack configuration
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_CALLBACK_URL=http://localhost:8080/booking/{id}/payment
PAYSTACK_ENABLE_MOCK_FALLBACK=true
PAYSTACK_MOCK_REDIRECT_URL_TEMPLATE=http://localhost:8080/booking/{id}/payment?reference={reference}

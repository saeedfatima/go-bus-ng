DJANGO_SECRET_KEY=django-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Paystack configuration
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# {id} is replaced with the booking UUID during payment initialization.
PAYSTACK_CALLBACK_URL=http://localhost:8080/booking/{id}/payment
# Hybrid fallback (only used in DEBUG). If unset, it defaults to DEBUG value.
PAYSTACK_ENABLE_MOCK_FALLBACK=true
# Used only when fallback is active and real gateway config is invalid.
PAYSTACK_MOCK_REDIRECT_URL_TEMPLATE=http://localhost:8080/booking/{id}/payment?reference={reference}
